<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <layer-list>
            <item
                android:width="24dp"
                android:height="24dp"
                android:drawable="@mipmap/ic_password_visible"
                android:gravity="center" />
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item
                android:width="24dp"
                android:height="24dp"
                android:drawable="@mipmap/ic_password_invisible"
                android:gravity="center" />
        </layer-list>
    </item>
</selector>
