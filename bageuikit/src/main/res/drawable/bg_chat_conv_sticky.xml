<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/screen_bg_selected" />
            <stroke
                android:width="1dp"
                android:color="@color/colorAccent" />
            <corners android:radius="@dimen/layout_bg_corner_radius" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/screen_bg" />
            <stroke
                android:width="1dp"
                android:color="@color/colorAccent" />
            <corners android:radius="@dimen/layout_bg_corner_radius" />
        </shape>
    </item>
</selector>
